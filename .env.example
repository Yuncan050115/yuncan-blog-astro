# ===========================================
# 站点信息（PUBLIC_ 前缀，构建时注入前端）
# ===========================================
# 站点名称
PUBLIC_SITE_NAME="我的博客"
# 作者
PUBLIC_SITE_AUTHOR="你的名字"
# SEO 关键词（逗号分隔）
PUBLIC_SITE_KEYWORDS="博客,个人博客,Astro"
# 站点简介
PUBLIC_SITE_DESC="一句话介绍你的站点"
# 站点地址
PUBLIC_SITE_URL="https://example.com"
# 站点主图标路径
PUBLIC_SITE_LOGO="/assets/logo-yuncan.png"
# Apple 端图标路径
PUBLIC_SITE_APPLE_LOGO="/assets/logo-yuncan.png"
# 建站日期（YYYY-MM-DD 格式）
PUBLIC_SITE_START="2026-01-01"
# ICP 备案号（可为空）
PUBLIC_SITE_ICP=""

# ===========================================
# API 配置（PUBLIC_ 前缀，前端需要使用）
# ===========================================
# Twikoo 云函数 API 链接
# 部署参考：https://twikoo.js.org/
# 未配置则不显示评论区
PUBLIC_TWIKOO_API=""

# MetingJS 音乐 API 链接
# 参照 https://github.com/Yuncan050115/script_netease 项目自建 API 服务
# 完整示例：https://你的网址/api?server=:server&type=:type&id=:id&r=:r
# 未配置则不显示音乐播放器
PUBLIC_METING_API=""

# 播放歌单 ID
# 网易云音乐歌单 ID，如 817519033
# 未配置则不显示音乐播放器
PUBLIC_SONG_ID=""

# 默认背景图片 API
# 可选值：必应随机 https://bing.ee123.net/img/rand
#         随机壁纸 https://wp.upx8.com/api.php
# 未配置则使用默认背景
PUBLIC_BG_IMAGE_API="https://bing.ee123.net/img/rand"

# Steam API Key
# 从 https://steamcommunity.com/dev/apikey 获取
PUBLIC_STEAM_API_KEY=""

# B 站 UID（用于 astro-bangumi 追番追剧动态获取）
PUBLIC_BILIBILI_UID=""

# 朋友圈 API 链接（友链朋友圈聚合服务）
# 部署仓库必须是 https://github.com/Yuncan050115/hexo-circle-of-friends
# fc_settings.yaml的配置修改为：LINK 改为 网址/social/link/ ，theme 改为 yuncan
# 未配置则不显示朋友圈页面内容，示例：你的地址/all
PUBLIC_CIRCLE_API=""

# ===========================================
# 敏感凭证（无 PUBLIC_ 前缀，不暴露到前端 JS）
# ===========================================
# 文章管理页密码
# 设置后，通过连续点击 FPS 区域 2 次触发隐藏入口
# 未设置则管理页不可用
POST_PASSWORD=""

# GitHub fine-grained token
# 创建地址：https://github.com/settings/personal-access-tokens/new
# 权限设置：仅选择目标仓库
#           Contents: Read and write
# 安全提示：请使用 fine-grained token，不要使用 classic token
#           仅授权特定仓库的 Contents 读写权限，不要授予其他权限
GITHUB_TOKEN=""

# GitHub 仓库地址
GITHUB_REPO=""

# 源码分支（默认 master）
GITHUB_BRANCH="master"
