---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import PostCard from '../../components/PostCard.astro';
import { getTaxonomy } from '../../lib/content';

export function getStaticPaths() {
  return getTaxonomy('categories').map((category) => ({ params: { category: category.slug }, props: { category } }));
}

const { category } = Astro.props;
---

<BaseLayout title={`分类：${category.name}`}>
  <PageHero title={category.name} eyebrow="CATEGORY" description={`${category.posts.length} 篇文章`} />
  <section class="content-shell post-grid">
    {category.posts.map((post) => <PostCard post={post} />)}
  </section>
</BaseLayout>
